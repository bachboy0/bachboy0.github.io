---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeContent from "../components/HomeContent.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
---

<script>
  (function () {
    const hasRedirected = sessionStorage.getItem("lang-redirected");
    if (hasRedirected) return;
    const userLang = navigator.language || navigator.languages?.[0] || "";
    const langCode = userLang.toLowerCase().split("-")[0];
    if (langCode === "ja") {
      sessionStorage.setItem("lang-redirected", "true");
      window.location.href = "/ja/";
    } else if (langCode === "ko") {
      sessionStorage.setItem("lang-redirected", "true");
      window.location.href = "/ko/";
    }
  })();
</script>

<BaseLayout
  title={t("site.title")}
  description={t("site.description")}
  mainClass="!w-full !max-w-full !p-0 flex flex-col gap-0 overflow-hidden"
>
  <HomeContent lang="en" />
</BaseLayout>
