---
---
<button
  class="theme-toggle p-2 rounded focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
  aria-label="Toggle Dark Mode"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="sun-icon w-6 h-6"
    fill="none"   
    viewBox="0 0 24 24"
    stroke="black"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707.707M6.343 6.343l-.707.707m12.728 0l.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
   
  />
  </svg>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="moon-icon w-6 h-6 hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >             
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    />
  
 </svg>
</button>     

<script>
  const buttons = document.querySelectorAll('.theme-toggle');
  const themeKey = 'theme';

  /**
   * 現在のテーマに基づいて全てのボタンのアイコン表示を同期する関数
   * @param {boolean} isDark - 現在ダークモードであるか
   */
  function syncIcons(isDark: boolean) {
    buttons.forEach(button => {
      const sunIcon = button.querySelector('.sun-icon');
      const moonIcon = button.querySelector('.moon-icon');
      if (sunIcon && moonIcon) {
        sunIcon.classList.toggle('hidden', isDark);
        moonIcon.classList.toggle('hidden', !isDark);
      }
    });
  }

  // 1. 初期ロード時のアイコン状態同期
  // <head>のスクリプトですでに設定されたクラスを確認
  const initialIsDark = document.documentElement.classList.contains('dark');
  syncIcons(initialIsDark);

  // 2. クリック時の処理（全てのボタンにイベントリスナーを追加）
  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      
      localStorage.setItem(themeKey, isDark ? 'dark' : 'light');
      
      // 全てのアイコンを更新
      syncIcons(isDark);
    });
  });
</script>