---
import ProjectCard from "./ProjectCard.astro";
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- HERO SECTION -->
<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center text-center px-4 py-20 overflow-hidden"
>
  <!-- Background gradient -->
  <div
    class="absolute inset-0 bg-linear-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-gray-900 dark:via-blue-950 dark:to-indigo-950"
  >
  </div>

  <!-- Animated background orbs -->
  <div
    class="absolute top-20 left-10 w-72 h-72 bg-blue-400/20 dark:bg-blue-500/20 rounded-full mix-blend-multiply dark:mix-blend-overlay filter blur-3xl opacity-70 animate-pulse"
  >
  </div>
  <div
    class="absolute top-40 right-10 w-72 h-72 bg-purple-400/20 dark:bg-purple-500/20 rounded-full mix-blend-multiply dark:mix-blend-overlay filter blur-3xl opacity-70 animate-pulse [animation-delay:1000ms]"
  >
  </div>
  <div
    class="absolute -bottom-8 left-1/2 w-72 h-72 bg-indigo-400/20 dark:bg-indigo-500/20 rounded-full mix-blend-multiply dark:mix-blend-overlay filter blur-3xl opacity-70 animate-pulse [animation-delay:2000ms]"
  >
  </div>
  <div
    class="absolute top-1/2 left-1/4 w-96 h-96 bg-cyan-400/10 dark:bg-cyan-500/10 rounded-full mix-blend-multiply dark:mix-blend-overlay filter blur-3xl opacity-50 animate-pulse [animation-delay:500ms]"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-pink-400/15 dark:bg-pink-500/15 rounded-full mix-blend-multiply dark:mix-blend-overlay filter blur-3xl opacity-60 animate-pulse [animation-delay:1500ms]"
  >
  </div>

  <!-- Decorative slow-spinning rings -->
  <div
    class="absolute top-12 left-12 w-28 h-28 border border-blue-300/25 dark:border-blue-500/20 rounded-full animate-spin [animation-duration:18s]"
  >
  </div>
  <div
    class="absolute top-6 left-6 w-40 h-40 border border-indigo-300/15 dark:border-indigo-500/15 rounded-full animate-spin [animation-duration:25s] [animation-direction:reverse]"
  >
  </div>
  <div
    class="absolute bottom-16 right-12 w-24 h-24 border border-purple-300/25 dark:border-purple-500/20 rounded-full animate-spin [animation-duration:14s]"
  >
  </div>
  <div
    class="absolute bottom-8 right-4 w-36 h-36 border border-pink-300/15 dark:border-pink-500/15 rounded-full animate-spin [animation-duration:22s] [animation-direction:reverse]"
  >
  </div>
  <!-- Center-area decorative ring -->
  <div
    class="absolute top-1/3 right-1/5 w-16 h-16 border border-cyan-300/20 dark:border-cyan-500/20 rounded-full animate-spin [animation-duration:10s]"
  >
  </div>

  <!-- Floating particles -->
  <div
    class="absolute top-1/4 left-1/3 w-2 h-2 bg-blue-400/70 dark:bg-blue-400/50 rounded-full animate-float"
  >
  </div>
  <div
    class="absolute top-1/3 right-1/4 w-1.5 h-1.5 bg-purple-400/70 dark:bg-purple-400/50 rounded-full animate-float [animation-delay:700ms]"
  >
  </div>
  <div
    class="absolute bottom-1/3 left-1/5 w-2 h-2 bg-indigo-400/70 dark:bg-indigo-400/50 rounded-full animate-float [animation-delay:1200ms]"
  >
  </div>
  <div
    class="absolute top-2/3 right-1/3 w-1.5 h-1.5 bg-cyan-400/70 dark:bg-cyan-400/50 rounded-full animate-float [animation-delay:300ms]"
  >
  </div>
  <div
    class="absolute top-1/5 right-1/5 w-3 h-3 bg-pink-400/50 dark:bg-pink-400/40 rounded-full animate-float [animation-delay:1800ms]"
  >
  </div>
  <div
    class="absolute bottom-1/4 left-2/5 w-1.5 h-1.5 bg-violet-400/60 dark:bg-violet-400/40 rounded-full animate-float [animation-delay:900ms]"
  >
  </div>
  <div
    class="absolute top-3/5 left-1/6 w-2 h-2 bg-sky-400/60 dark:bg-sky-400/40 rounded-full animate-float [animation-delay:2200ms]"
  >
  </div>

  <div class="relative z-10 hero-content max-w-5xl mx-auto">
    <!-- Animated status badge with ping -->
    <div class="flex justify-center mb-8 animate-fade-in-up">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm border border-blue-200 dark:border-blue-800 shadow-lg shadow-blue-500/10"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"
          ></span>
        </span>
        <span
          class="text-xs font-bold text-gray-600 dark:text-gray-300 tracking-widest uppercase"
          >Open to opportunities</span
        >
      </div>
    </div>

    <h1
      id="hero-title"
      class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black mb-6 bg-linear-to-r from-blue-600 via-indigo-600 to-purple-600 dark:from-blue-400 dark:via-indigo-400 dark:to-purple-400 bg-clip-text text-transparent leading-tight animate-fade-in-up [animation-delay:150ms]"
    >
      {t("hero.greeting")}
      <span class="block mt-2">{t("site.title")}</span>
    </h1>

    <p
      class="text-xl sm:text-2xl lg:text-3xl text-gray-600 dark:text-gray-300 mb-4 max-w-3xl mx-auto font-light leading-relaxed animate-fade-in-up [animation-delay:300ms]"
    >
      {t("hero.tagline")}
    </p>

    <p
      class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-12 max-w-3xl mx-auto animate-fade-in-up [animation-delay:450ms]"
    >
      <span
        class="bg-linear-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent"
        >{t("hero.code")}</span
      >
      <span class="text-gray-400 dark:text-gray-500 mx-2">×</span>
      <span
        class="bg-linear-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent"
        >{t("hero.design")}</span
      >
      <span class="text-gray-400 dark:text-gray-500 mx-2">×</span>
      <span
        class="bg-linear-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 bg-clip-text text-transparent"
        >{t("hero.innovation")}</span
      >
    </p>

    <div
      class="flex gap-4 justify-center flex-wrap mb-8 animate-fade-in-up [animation-delay:600ms]"
    >
      <a
        href="https://github.com/bachboy0"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-bold text-lg transition-all duration-500 bg-linear-to-r from-blue-600 to-indigo-600 text-white hover:shadow-2xl hover:shadow-blue-500/50 hover:scale-105 hover:-translate-y-1 active:scale-95 overflow-hidden"
      >
        <span class="relative z-10">🐙 {t("hero.github")}</span>
        <!-- Gradient overlay on hover -->
        <span
          class="absolute inset-0 bg-linear-to-r from-indigo-600 to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        ></span>
        <!-- Shimmer sweep on hover -->
        <span
          class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 bg-linear-to-r from-transparent via-white/25 to-transparent"
        ></span>
      </a>
      <a
        href="/blog"
        class="group inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-bold text-lg transition-all duration-500 bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm text-gray-900 dark:text-white border-2 border-blue-300 dark:border-blue-700 hover:bg-linear-to-r hover:from-blue-600 hover:to-indigo-600 hover:text-white hover:border-transparent hover:shadow-2xl hover:shadow-blue-500/30 hover:scale-105 hover:-translate-y-1 active:scale-95"
      >
        <span>📝 {t("blog.badge")}</span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator (positioned relative to the section, not hero-content) -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 z-10 animate-fade-in-up [animation-delay:900ms]"
  >
    <span
      class="text-xs font-semibold text-gray-400 dark:text-gray-600 tracking-widest uppercase"
      >{t("hero.scroll")}</span
    >
    <div class="animate-bounce">
      <svg
        class="w-6 h-6 text-gray-400 dark:text-gray-600"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>

<!-- BLOG PREVIEW SECTION -->
<section
  id="blog-preview"
  class="relative px-6 py-24 sm:py-32 bg-linear-to-b from-white to-gray-50 dark:from-gray-950 dark:to-gray-900"
>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-linear-to-r from-blue-100 to-indigo-100 dark:from-blue-950 dark:to-indigo-950 border border-blue-200 dark:border-blue-800"
      >
        <svg
          class="w-4 h-4 text-blue-600 dark:text-blue-400"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v4H5V6zm6 6H5v2h6v-2z"
          ></path>
          <path d="M15 7h1a2 2 0 012 2v5.5a1.5 1.5 0 01-3 0V7z"></path>
        </svg>
        <span class="text-sm font-semibold text-blue-600 dark:text-blue-400">
          {t("blog.badge")}
        </span>
      </div>

      <h2
        class="py-4 text-4xl sm:text-5xl lg:text-6xl font-black mb-6 bg-linear-to-r from-gray-900 via-blue-900 to-indigo-900 dark:from-gray-100 dark:via-blue-100 dark:to-indigo-100 bg-clip-text text-transparent"
      >
        {t("blog.title")}
      </h2>

      <p
        class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed"
      >
        {t("blog.description.prefix")}
        <span class="font-semibold text-gray-900 dark:text-white"
          >{t("blog.description.web")}</span
        >,
        <span class="font-semibold text-gray-900 dark:text-white"
          >{t("blog.description.oss")}</span
        >,
        <span class="font-semibold text-gray-900 dark:text-white"
          >{t("blog.description.tech")}</span
        >
      </p>
    </div>

    <div class="flex justify-center">
      <a
        href="/blog"
        class="group relative inline-flex items-center gap-3 px-10 py-5 rounded-2xl font-bold text-lg transition-all duration-500 bg-linear-to-r from-blue-600 to-indigo-600 text-white hover:shadow-2xl hover:shadow-blue-500/40 hover:scale-105 active:scale-95 overflow-hidden"
      >
        <span class="relative z-10 flex items-center gap-3">
          <span>{t("blog.cta")}</span>
          <svg
            class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </span>
        <span
          class="absolute inset-0 bg-linear-to-r from-indigo-600 to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        ></span>
        <span
          class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 bg-linear-to-r from-transparent via-white/20 to-transparent"
        ></span>
      </a>
    </div>
  </div>
</section>

<!-- FEATURED PROJECTS SECTION -->
<section
  id="projects"
  class="relative px-6 py-24 sm:py-32 bg-white dark:bg-gray-950"
>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-linear-to-r from-purple-100 to-pink-100 dark:from-purple-950 dark:to-pink-950 border border-purple-200 dark:border-purple-800"
      >
        <svg
          class="w-4 h-4 text-purple-600 dark:text-purple-400"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            fill-rule="evenodd"
            d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
        <span
          class="text-sm font-semibold text-purple-600 dark:text-purple-400"
        >
          {t("projects.badge")}
        </span>
      </div>

      <h2
        class="py-4 text-4xl sm:text-5xl lg:text-6xl font-black mb-6 bg-linear-to-r from-purple-900 via-pink-900 to-rose-900 dark:from-purple-100 dark:via-pink-100 dark:to-rose-100 bg-clip-text text-transparent"
      >
        {t("projects.title")}
      </h2>

      <p
        class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed"
      >
        {t("projects.description")}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      <div class="group relative">
        <div
          class="absolute inset-0 bg-linear-to-r from-blue-500 to-indigo-500 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>
        <div
          class="relative bg-white dark:bg-gray-900 rounded-3xl p-8 border border-gray-200 dark:border-gray-800 transition-all duration-500 hover:border-blue-500 dark:hover:border-blue-400 hover:-translate-y-2 hover:shadow-2xl"
        >
          <ProjectCard
            title={t("projects.nginx.title")}
            description={t("projects.nginx.description")}
            tag="Python"
          />
        </div>
      </div>

      <div class="group relative">
        <div
          class="absolute inset-0 bg-linear-to-r from-purple-500 to-pink-500 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>
        <div
          class="relative bg-white dark:bg-gray-900 rounded-3xl p-8 border border-gray-200 dark:border-gray-800 transition-all duration-500 hover:border-purple-500 dark:hover:border-purple-400 hover:-translate-y-2 hover:shadow-2xl"
        >
          <ProjectCard
            title={t("projects.montecarlo.title")}
            description={t("projects.montecarlo.description")}
            tag="Python"
          />
        </div>
      </div>

      <div class="group relative">
        <div
          class="absolute inset-0 bg-linear-to-r from-yellow-500 to-orange-500 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>
        <div
          class="relative bg-white dark:bg-gray-900 rounded-3xl p-8 border border-gray-200 dark:border-gray-800 transition-all duration-500 hover:border-yellow-500 dark:hover:border-yellow-400 hover:-translate-y-2 hover:shadow-2xl"
        >
          <ProjectCard
            title={t("projects.takubook.title")}
            description={t("projects.takubook.description")}
            tag="Svelte"
            href="https://takubook.com"
          />
        </div>
      </div>
    </div>

    <div class="text-center">
      <a
        href="https://github.com/bachboy0"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 text-lg font-bold text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300"
      >
        <span>{t("projects.github")}</span>
        <svg
          class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- SKILLS SECTION -->
<section
  id="skills"
  class="relative px-6 py-24 sm:py-32 bg-linear-to-br from-gray-50 via-blue-50 to-indigo-50 dark:from-gray-900 dark:via-blue-950/30 dark:to-indigo-950/30"
>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-linear-to-r from-indigo-100 to-blue-100 dark:from-indigo-950 dark:to-blue-950 border border-indigo-200 dark:border-indigo-800"
      >
        <svg
          class="w-4 h-4 text-indigo-600 dark:text-indigo-400"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.859a4 4 0 10-4.954 0c.27.213.462.519.476.859h4.002z"
          ></path>
        </svg>
        <span
          class="text-sm font-semibold text-indigo-600 dark:text-indigo-400"
        >
          {t("skills.badge")}
        </span>
      </div>

      <h2
        class="py-4 text-4xl sm:text-5xl lg:text-6xl font-black mb-6 bg-linear-to-r from-indigo-900 via-blue-900 to-cyan-900 dark:from-indigo-100 dark:via-blue-100 dark:to-cyan-100 bg-clip-text text-transparent"
      >
        {t("skills.title")}
      </h2>

      <p
        class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed"
      >
        {t("skills.description")}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Languages Card -->
      <div class="group relative">
        <div
          class="absolute inset-0 bg-linear-to-br from-blue-500 to-cyan-500 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>
        <div
          class="relative bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm rounded-3xl p-8 border border-gray-200 dark:border-gray-800 hover:border-blue-400 dark:hover:border-blue-500 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
        >
          <div class="flex items-center gap-3 mb-6">
            <div
              class="p-3 bg-linear-to-br from-blue-500 to-cyan-500 rounded-2xl"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white">
              {t("skills.languages")}
            </h3>
          </div>
          <ul class="space-y-4">
            <li
              class="flex items-center gap-3 py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200"
            >
              <span
                class="shrink-0 w-8 h-8 flex items-center justify-center bg-linear-to-br from-blue-500 to-cyan-500 rounded-lg text-white font-bold text-sm"
                >P</span
              >
              <span class="font-medium text-lg">Python</span>
            </li>
            <li
              class="flex items-center gap-3 py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200"
            >
              <span
                class="shrink-0 w-8 h-8 flex items-center justify-center bg-linear-to-br from-yellow-500 to-orange-500 rounded-lg text-white font-bold text-sm"
                >JS</span
              >
              <span class="font-medium text-lg">JavaScript</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Web Development Card -->
      <div class="group relative">
        <div
          class="absolute inset-0 bg-linear-to-br from-indigo-500 to-purple-500 rounded-3xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-500"
        >
        </div>
        <div
          class="relative bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm rounded-3xl p-8 border border-gray-200 dark:border-gray-800 hover:border-indigo-400 dark:hover:border-indigo-500 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
        >
          <div class="flex items-center gap-3 mb-6">
            <div
              class="p-3 bg-linear-to-br from-indigo-500 to-purple-500 rounded-2xl"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                ></path>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white">
              {t("skills.webdev")}
            </h3>
          </div>
          <ul class="space-y-4">
            {
